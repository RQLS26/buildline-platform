@BuildlinePlatform_HostAddress = http://localhost:5163
@SignInEmail = user@example.com
@SignInPassword = change-me
@NewUserName = Operations User
@NewUserEmail = new-user@example.com
@NewUserPassword = change-me-too
@NewUserRole = viewer
@NewUserDepartment = Operations
@NewUserPhone = +51 900 000 000
@NewUserAvatarColor = #3D9F7D
@SampleMaterial = Steel Rebar 1/2
@SampleProject = Skyline Tower
@SampleQuantity = 250
@SampleUnit = PCS
@SamplePriority = High
@SampleRequestedBy = Carlos Mendoza
@SampleDeliveryDate = 2026-05-30
@PurchaseOrderId = 2
@PurchaseOrderStatus = Approved
@InventoryItemId = 1
@InventoryCurrentStock = 120
@InventoryLastUpdated = 2026-06-15
@MessageId = 2
@MessageRead = true
@AccessToken = {{signIn.response.body.$.token}}
@CompanyId = {{signIn.response.body.$.companyId}}

### Health
GET {{BuildlinePlatform_HostAddress}}/api/v1/health
Accept: application/json

### Sign in
# @name signIn
POST {{BuildlinePlatform_HostAddress}}/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "{{SignInEmail}}",
  "password": "{{SignInPassword}}"
}

### Sign up
POST {{BuildlinePlatform_HostAddress}}/api/v1/auth/sign-up
Content-Type: application/json

{
  "name": "{{NewUserName}}",
  "email": "{{NewUserEmail}}",
  "password": "{{NewUserPassword}}",
  "role": "{{NewUserRole}}",
  "department": "{{NewUserDepartment}}",
  "phone": "{{NewUserPhone}}",
  "avatarColor": "{{NewUserAvatarColor}}"
}

### Users
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/users
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Profiles
GET {{BuildlinePlatform_HostAddress}}/api/v1/profiles
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Projects
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/projects
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Categories
GET {{BuildlinePlatform_HostAddress}}/api/v1/categories
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Materials
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/materials
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Requisitions
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/requisitions
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Create requisition
POST {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/requisitions
Content-Type: application/json
Authorization: Bearer {{AccessToken}}

{
  "material": "{{SampleMaterial}}",
  "project": "{{SampleProject}}",
  "quantity": {{SampleQuantity}},
  "unit": "{{SampleUnit}}",
  "priority": "{{SamplePriority}}",
  "requestedBy": "{{SampleRequestedBy}}",
  "deliveryDate": "{{SampleDeliveryDate}}"
}

### Purchase orders
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/purchaseOrders
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Patch purchase order status
PATCH {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/purchaseOrders/{{PurchaseOrderId}}
Content-Type: application/json
Authorization: Bearer {{AccessToken}}

{
  "status": "{{PurchaseOrderStatus}}"
}

### Quotations
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/quotations
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Inventory
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/inventory
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Patch inventory stock
PATCH {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/inventory/{{InventoryItemId}}
Content-Type: application/json
Authorization: Bearer {{AccessToken}}

{
  "currentStock": {{InventoryCurrentStock}},
  "lastUpdated": "{{InventoryLastUpdated}}"
}

### Deliveries
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/deliveries
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Suppliers
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/suppliers
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Incidents
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/incidents
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Budgets
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/budgets
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Messages
GET {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/messages
Accept: application/json
Authorization: Bearer {{AccessToken}}

### Mark message as read
PATCH {{BuildlinePlatform_HostAddress}}/api/v1/companies/{{CompanyId}}/messages/{{MessageId}}
Content-Type: application/json
Authorization: Bearer {{AccessToken}}

{
  "isRead": {{MessageRead}}
}

